rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "jializhou93@gmail.com" && request.auth.token.email_verified == true);
    }

    // Validator for SectionMedia
    function isValidSectionMedia(data) {
      return data.keys().hasAll(['media']) &&
             data.media is list &&
             (data.get('updatedAt', null) == null || data.updatedAt is timestamp);
    }

    match /sections/{sectionId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSectionMedia(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin();
    }

    // For connection test
    match /test/connection {
      allow read: if true;
    }
  }
}
